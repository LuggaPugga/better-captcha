{
	"name": "better-captcha",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"build:packages": "turbo run build --filter=@better-captcha/core --filter=@better-captcha/preact --filter=@better-captcha/react --filter=@better-captcha/vue --filter=@better-captcha/svelte --filter=@better-captcha/solidjs --filter=@better-captcha/qwik --filter=@better-captcha/lit --filter=packages/*",
		"build:testing": "turbo run build --filter=apps/testing/*",
		"build:examples": "turbo run build --filter=apps/examples/*",
		"dev:react": "turbo run dev --filter=@better-captcha/react --filter=testing-react",
		"dev:preact": "turbo run dev --filter=@better-captcha/preact --filter=preact-testing",
		"dev:solid": "turbo run dev --filter=@better-captcha/solidjs --filter=testing-solid",
		"dev:vue": "turbo run dev --filter=@better-captcha/vue --filter=testing-vue",
		"dev:qwik": "turbo run dev --filter=@better-captcha/qwik --filter=testing-qwik",
		"dev:lit": "turbo run dev --filter=@better-captcha/lit --filter=lit-testing",
		"dev:docs": "turbo run dev --filter=@better-captcha/docs",
		"format": "biome format --write",
		"lint": "turbo run lint",
		"typecheck": "turbo run check-types",
		"start": "turbo run start",
		"changeset": "changeset",
		"ci:version": "changeset version && bun update",
		"ci:publish": "for dir in packages/core packages/react packages/vue packages/svelte packages/solidjs packages/qwik packages/lit packages/preact; do (cd \"$dir\" && bun publish --access public || true); done && changeset tag"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"ts-morph": "^27.0.2",
		"turbo": "^2.9.0",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "bun@1.3.0",
	"workspaces": [
		"apps/*",
		"apps/testing/*",
		"apps/examples/*",
		"packages/*"
	]
}
